includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    paths:
        - app
        - config
        - database/factories
        - database/seeders
        - routes
        - tests

    level: 6

    tmpDir: storage/framework/cache/phpstan

    reportUnmatchedIgnoredErrors: false

    excludePaths:
        - app/Console/Kernel.php
        - bootstrap/*
        - storage/*
        - vendor/*

    ignoreErrors:
        # Eloquent dynamic relations: Larastan resolves them, but property-fetch on $model->relation may need refinement.
        - identifier: missingType.iterableValue
        # Sentry/3rd-party facade dynamic helpers we cannot annotate.
        - '#Call to an undefined method Sentry\\State\\HubInterface::.*#'

    parallel:
        maximumNumberOfProcesses: 4
        processTimeout: 300.0
